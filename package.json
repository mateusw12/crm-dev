{
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:backend": "npm --prefix apps/backend run start:dev",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "install:all": "npm install --prefix apps/backend && npm install --prefix apps/frontend",
    "build:backend": "npm --prefix apps/backend run build",
    "build:frontend": "npm --prefix apps/frontend run build"
  }
}
